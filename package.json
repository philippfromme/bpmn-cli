{
  "name": "@philippfromme/bpmn-cli",
  "version": "0.1.0",
  "description": "Agent-first inspection, tracing, safe editing, linting, semantic diffing, and layout for BPMN.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philippfromme/bpmn-cli.git"
  },
  "bugs": {
    "url": "https://github.com/philippfromme/bpmn-cli/issues"
  },
  "homepage": "https://github.com/philippfromme/bpmn-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "bin": {
    "bpmn-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "npm run build && node --test \"dist/*.test.js\"",
    "test:coverage": "npm run build && node --test --experimental-test-coverage \"dist/*.test.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "bpmn-auto-layout": "github:bpmn-io/bpmn-auto-layout#7351d19e9838a2923e4182c85effc33f74160224",
    "bpmn-js-differ": "github:bpmn-io/bpmn-js-differ#d55ca44ce5c3379bd852dbec97665d2713e5c086",
    "bpmn-moddle": "^10.0.0",
    "bpmnlint": "^11.12.1",
    "canonicalize": "^2.1.0",
    "zeebe-bpmn-moddle": "^1.16.0"
  }
}
