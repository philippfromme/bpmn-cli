{
  "name": "bpmn-cli",
  "version": "0.1.0",
  "description": "A safe, scriptable foundation for future BPMN moddle editing.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bpmn-cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "npm run build && node --test dist/index.test.js",
    "test:coverage": "npm run build && node --test --experimental-test-coverage dist/index.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  }
}
