{
  "name": "bpmn-cli",
  "version": "0.1.0",
  "description": "Agent-first, bounded inspection and trace analysis of BPMN business semantics.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.12"
  },
  "bin": {
    "bpmn-cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "npm run build && node --test \"dist/*.test.js\"",
    "test:coverage": "npm run build && node --test --experimental-test-coverage \"dist/*.test.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "bpmn-moddle": "^10.0.0",
    "zeebe-bpmn-moddle": "^1.16.0"
  }
}
